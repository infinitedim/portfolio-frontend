# =============================================================================
# Portfolio Frontend — Environment Variables Example
#
# Local dev:  cp .env.example .env.development  (loaded by bun run dev)
# Production: copy values to .env for Vercel upload, or set in Vercel dashboard
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Base URL of the deployed site (used for Open Graph, sitemap, canonical URLs, RSS)
# Should match backend SITE_URL and NEXT_PUBLIC_BASE_URL in production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Optional server-side canonical base used by SSR referer checks
SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------------------
# Server-side URL used by Next.js SSR/API routes to call the Rust backend.
# Never exposed to the browser.
BACKEND_URL=http://localhost:8080

# Public backend API URL accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins for the Next.js proxy CORS check
ALLOWED_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Gate (Terminal access)
# ----------------------------------------------------------------------------
# Set to false to disable gate redirects (emergency disable)
NEXT_PUBLIC_GATE_ENABLED=true

# Server-only: dev bypass for /terminal without solving puzzles.
# Send header X-Gate-Bypass: <value> — NOT exposed to browser.
# GATE_BYPASS_SECRET=

# Gate puzzle secrets (backend only — see portfolio-backend/.env.example):
# GATE_L1_ANSWER, GATE_L2_ANSWER, GATE_TOKEN_SECRET, SITE_URL / FRONTEND_ORIGIN

# ----------------------------------------------------------------------------
# Giscus Comments (optional — get values from https://giscus.app)
# Requires: GitHub repo must be public + Discussions enabled
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GISCUS_REPO=owner/repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_xxxxxxxxxx

# Default / legacy fallback (dipakai jika category-specific ID tidak diset)
NEXT_PUBLIC_GISCUS_CATEGORY=Blog Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_xxxxxxxxxx

# Per-category IDs — isi sesuai Discussion categories yang sudah dibuat di GitHub
NEXT_PUBLIC_GISCUS_CATEGORY_ANNOUNCEMENTS=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID_ANNOUNCEMENTS=
NEXT_PUBLIC_GISCUS_CATEGORY_GENERAL=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID_GENERAL=
NEXT_PUBLIC_GISCUS_CATEGORY_IDEAS=Ideas
NEXT_PUBLIC_GISCUS_CATEGORY_ID_IDEAS=
NEXT_PUBLIC_GISCUS_CATEGORY_POLLS=Polls
NEXT_PUBLIC_GISCUS_CATEGORY_ID_POLLS=
NEXT_PUBLIC_GISCUS_CATEGORY_QA=Q&A
NEXT_PUBLIC_GISCUS_CATEGORY_ID_QA=
NEXT_PUBLIC_GISCUS_CATEGORY_SHOW_AND_TELL=Show and Tell
NEXT_PUBLIC_GISCUS_CATEGORY_ID_SHOW_AND_TELL=
NEXT_PUBLIC_GISCUS_CATEGORY_BLOG_COMMENTS=Blog Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID_BLOG_COMMENTS=

# ----------------------------------------------------------------------------
# SEO Verification (optional)
# ----------------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=
BING_VERIFICATION=

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
NEXT_PUBLIC_LOG_API_URL=/api/logs
NEXT_PUBLIC_LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Encryption / Crypto
# ----------------------------------------------------------------------------
# Session TTL in milliseconds (default: 900000 = 15 minutes)
# CRYPTO_SESSION_TTL=900000

# PBKDF2-SHA-256 iteration count (default: 100000)
# CRYPTO_PBKDF2_ITERATIONS=100000

# ----------------------------------------------------------------------------
# Roadmap.sh Integration (optional)
# ----------------------------------------------------------------------------
# Set ROADMAP_EMAIL and ROADMAP_PASSWORD in portfolio-backend/.env instead.

# ----------------------------------------------------------------------------
# GitHub Integration (optional)
# ----------------------------------------------------------------------------
# GH_TOKEN is configured on the backend for /api/github/* proxy rate limits.
# GH_USERNAME is used by SSR data fetching for default stats username.
GH_USERNAME=exampleuser

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# Grafana dashboard URL (linked from admin dashboard)
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# Vercel Speed Insights — no env required on Vercel; component mounts in production only.

# ----------------------------------------------------------------------------
# AI Assistant (optional — configured on backend)
# ----------------------------------------------------------------------------
# GEMINI_API_KEY in portfolio-backend/.env powers POST /api/ai/chat SSE.

# ----------------------------------------------------------------------------
# Headless CMS (optional — configured on backend)
# ----------------------------------------------------------------------------
# HEADLESS_CMS_ENABLED=true in portfolio-backend/.env enables /api/v1/content/*

# ----------------------------------------------------------------------------
# Newly Identified / Missing Variables
# ----------------------------------------------------------------------------
# Custom title for the RSS feed
# NEXT_PUBLIC_SITE_TITLE=

# Custom description for the RSS feed
# NEXT_PUBLIC_SITE_DESCRIPTION=

# Fallback website URL when site URL cannot be determined
# NEXT_PUBLIC_SITE_URL=

# Set to true to enable server-side file-based logging
# LOG_TO_FILE=false

# Set to true to analyze the bundle size (dev only)
# ANALYZE=false

# Custom base URL for E2E integration tests
# PLAYWRIGHT_BASE_URL=
