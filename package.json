{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:vitest": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx}\"",
    "type-check": "tsc --project tsconfig.json --pretty --noEmit",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "perf:analyze": "ANALYZE=true bun run build",
    "perf:lighthouse": "lhci autorun --config=lighthouserc.js",
    "perf:lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.js"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@giscus/react": "^3.1.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@tiptap/extension-heading": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lenis": "^1.3.25",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tiptap-markdown": "^0.9.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/mocker": "^4.1.9",
    "@vitest/snapshot": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@vitest/utils": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "cssnano": "^8.0.2",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "resolutions": {
    "csstype": "3.2.3"
  },
  "overrides": {
    "csstype": "3.2.3"
  }
}
